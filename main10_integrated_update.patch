+INSERT OR REPLACE INTO regular_expressions (name, pattern, description) VALUES ('4K Gate: Block Missing HDR', '(?i)^(?=.*\b(?:2160p|4k)\b)(?!.*(?:\bhdr\b|\bhdr10\b|\bhdr10plus\b|\bhdr10\+|\bdovi\b|\bdv\b|dolby[ ._-]?vision|\b(?:10[ ._-]?bit|10b|main[ ._-]?10|yuv420p10le)\b)).*$', 'Blocks or heavily penalizes 2160p/4K releases that advertise neither HDR/Dolby Vision nor explicit 10-bit/Main 10. This preserves HDR-first behavior while allowing 10-bit SDR as a controlled fallback.');
